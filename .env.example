# ─── TransitOps Email Configuration ─────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.template .env

# Gmail SMTP — use an App Password (not your regular password)
# Generate one at: https://myaccount.google.com/apppasswords
EMAIL_USER="sender-email@gmail.com"
EMAIL_PASSWORD="xxxx xxxx xxxx xxxx"

# (Optional) Redirect ALL reminder emails to a single test address
EMAIL_TEST_TO="your-test-email@gmail.com"
